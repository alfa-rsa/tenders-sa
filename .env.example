# tenders-sa — Environment Variables

# eTenders API
ETENDERS_BASE_URL=https://ocds-api.etenders.gov.za
ETENDERS_TIMEOUT=120

# Database (path to SQLite cache)
TENDERS_DB_PATH=./cache.db

# OpenClaw WhatsApp (for daily digest)
OPENCLAW_SESSION=main

# Google Workspace (optional — for Sheets export)
GWS_TOKEN_FILE=~/.config/gws/token.json
GWS_CREDENTIALS_FILE=~/.config/gws/client_secret.json
